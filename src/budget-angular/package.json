{
  "name": "budget-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "backend": "concurrently -k --names 'Api, Worker' --prefix-colors 'blue,magenta' 'dotnet run --project ../Budget.Api' 'sleep 2 && dotnet run --project ../Budget.Worker'"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.1.2",
    "@angular/compiler": "^21.1.2",
    "@angular/core": "^21.1.2",
    "@angular/forms": "^21.1.2",
    "@angular/platform-browser": "^21.1.2",
    "@angular/router": "^21.1.2",
    "@tailwindcss/postcss": "^4.1.18",
    "angular-oauth2-oidc": "^20.0.2",
    "bootstrap-icons": "^1.13.1",
    "daisyui": "^5.5.16",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.2",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.2",
    "baseline-browser-mapping": "^2.9.19",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.0",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
