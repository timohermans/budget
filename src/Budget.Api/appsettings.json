{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        // set to Debug when there's a console error
      }
    },
    "Properties": {
      "Environment": "Development",
      "Application": "Budget.Api"
    },
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341",
          "apiKey": ""
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Issuer": "",
    "Audiences": [""],
    "Authority": ""
  },
  "FileStorage": {
    "MaxSizeMb": "1",
    "BasePath": "./files/budget"
  },
  "ConnectionStrings": {
    "budgetdb": "",
    "nats": ""
  }
}
